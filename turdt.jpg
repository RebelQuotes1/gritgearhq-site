<svg width="100%" viewBox="0 0 690 410" role="img" xmlns="http://www.w3.org/2000/svg" style="">
  <title style="fill:rgb(0, 0, 0);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto">Titan Survival SurvivorCord thumbnail ad</title>
  <desc style="fill:rgb(0, 0, 0);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto">A rugged thumbnail ad for Titan Survival's SurvivorCord product featuring bold military styling</desc>
  <defs>
    <marker id="arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
      <path d="M2 1L8 5L2 9" fill="none" stroke="context-stroke" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </marker>
    <pattern id="hex" x="0" y="0" width="28" height="32" patternUnits="userSpaceOnUse">
      <polygon points="14,2 26,9 26,23 14,30 2,23 2,9" fill="none" stroke="#2a2a1a" stroke-width="0.5" opacity="0.4"/>
    </pattern>
    <clipPath id="clip-main">
      <rect x="0" y="0" width="680" height="400" rx="12"/>
    </clipPath>
  </defs>

  <g clip-path="url(#clip-main)" style="fill:rgb(0, 0, 0);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto">
    <!-- Background: dark military olive -->
    <rect x="0" y="0" width="680" height="400" fill="#1a1f0f" style="fill:rgb(26, 31, 15);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
    <!-- Hex pattern overlay -->
    <rect x="0" y="0" width="680" height="400" fill="url(#hex)" style="stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

    <!-- Right side rope visual - orange coil rings -->
    <ellipse cx="560" cy="200" rx="100" ry="145" fill="none" stroke="#E55A00" stroke-width="12" opacity="0.9" style="fill:none;stroke:rgb(229, 90, 0);color:rgb(0, 0, 0);stroke-width:12px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.9;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
    <ellipse cx="560" cy="200" rx="78" ry="118" fill="none" stroke="#CC4A00" stroke-width="11" opacity="0.85" style="fill:none;stroke:rgb(204, 74, 0);color:rgb(0, 0, 0);stroke-width:11px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.85;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
    <ellipse cx="560" cy="200" rx="56" ry="92" fill="none" stroke="#E55A00" stroke-width="10" opacity="0.75" style="fill:none;stroke:rgb(229, 90, 0);color:rgb(0, 0, 0);stroke-width:10px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.75;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
    <ellipse cx="560" cy="200" rx="36" ry="65" fill="none" stroke="#A33800" stroke-width="9" opacity="0.7" style="fill:none;stroke:rgb(163, 56, 0);color:rgb(0, 0, 0);stroke-width:9px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.7;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
    <!-- Highlight strand -->
    <ellipse cx="560" cy="200" rx="100" ry="145" fill="none" stroke="#FF7A20" stroke-width="3" opacity="0.5" stroke-dasharray="20 60" style="fill:none;stroke:rgb(255, 122, 32);color:rgb(0, 0, 0);stroke-width:3px;stroke-dasharray:20px, 60px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.5;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

    <!-- Left accent bar -->
    <rect x="0" y="0" width="6" height="400" fill="#E55A00" style="fill:rgb(229, 90, 0);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

    <!-- Top badge: VETERAN OWNED -->
    <rect x="36" y="28" width="180" height="26" rx="4" fill="#2d3318" stroke="#4a5220" stroke-width="0.5" style="fill:rgb(45, 51, 24);stroke:rgb(74, 82, 32);color:rgb(0, 0, 0);stroke-width:0.5px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
    <text x="46" y="45" font-family="'Courier New', monospace" font-size="11" fill="#8fa040" letter-spacing="2" font-weight="700" style="fill:rgb(143, 160, 64);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Courier New&quot;, monospace;font-size:11px;font-weight:700;text-anchor:start;dominant-baseline:auto">★ VETERAN OWNED ★</text>

    <!-- Main headline: SURVIVORCORD -->
    <text x="36" y="140" font-family="'Impact', 'Arial Black', sans-serif" font-size="72" fill="#E55A00" letter-spacing="-1" style="fill:rgb(229, 90, 0);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Impact, &quot;Arial Black&quot;, sans-serif;font-size:72px;font-weight:400;text-anchor:start;dominant-baseline:auto">SURVIVOR</text>
    <text x="36" y="210" font-family="'Impact', 'Arial Black', sans-serif" font-size="72" fill="#F5F0E0" letter-spacing="-1" style="fill:rgb(245, 240, 224);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Impact, &quot;Arial Black&quot;, sans-serif;font-size:72px;font-weight:400;text-anchor:start;dominant-baseline:auto">CORD</text>

    <!-- Divider line -->
    <rect x="36" y="222" width="360" height="3" fill="#E55A00" rx="1" style="fill:rgb(229, 90, 0);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

    <!-- Subheadline -->
    <text x="36" y="252" font-family="'Courier New', monospace" font-size="13" fill="#aab060" letter-spacing="1" style="fill:rgb(170, 176, 96);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Courier New&quot;, monospace;font-size:13px;font-weight:400;text-anchor:start;dominant-baseline:auto">MIL-STYLE 620 LB PARACORD</text>

    <!-- Feature pills -->
    <rect x="36" y="268" width="110" height="22" rx="3" fill="#2d3318" stroke="#E55A00" stroke-width="0.5" style="fill:rgb(45, 51, 24);stroke:rgb(229, 90, 0);color:rgb(0, 0, 0);stroke-width:0.5px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
    <text x="91" y="283" font-family="'Courier New', monospace" font-size="10" fill="#E55A00" text-anchor="middle" letter-spacing="0.5" style="fill:rgb(229, 90, 0);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Courier New&quot;, monospace;font-size:10px;font-weight:400;text-anchor:middle;dominant-baseline:auto">FISHING LINE</text>

    <rect x="154" y="268" width="108" height="22" rx="3" fill="#2d3318" stroke="#E55A00" stroke-width="0.5" style="fill:rgb(45, 51, 24);stroke:rgb(229, 90, 0);color:rgb(0, 0, 0);stroke-width:0.5px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
    <text x="208" y="283" font-family="'Courier New', monospace" font-size="10" fill="#E55A00" text-anchor="middle" letter-spacing="0.5" style="fill:rgb(229, 90, 0);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Courier New&quot;, monospace;font-size:10px;font-weight:400;text-anchor:middle;dominant-baseline:auto">FIRE STARTER</text>

    <rect x="270" y="268" width="110" height="22" rx="3" fill="#2d3318" stroke="#E55A00" stroke-width="0.5" style="fill:rgb(45, 51, 24);stroke:rgb(229, 90, 0);color:rgb(0, 0, 0);stroke-width:0.5px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
    <text x="325" y="283" font-family="'Courier New', monospace" font-size="10" fill="#E55A00" text-anchor="middle" letter-spacing="0.5" style="fill:rgb(229, 90, 0);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Courier New&quot;, monospace;font-size:10px;font-weight:400;text-anchor:middle;dominant-baseline:auto">SNARE WIRE</text>

    <!-- CTA Button -->
    <rect x="36" y="316" width="200" height="48" rx="4" fill="#E55A00" style="fill:rgb(229, 90, 0);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
    <rect x="36" y="316" width="200" height="48" rx="4" fill="none" stroke="#FF7A20" stroke-width="1" style="fill:none;stroke:rgb(255, 122, 32);color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
    <text x="136" y="346" font-family="'Impact', 'Arial Black', sans-serif" font-size="18" fill="#1a1f0f" text-anchor="middle" letter-spacing="1" style="fill:rgb(26, 31, 15);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Impact, &quot;Arial Black&quot;, sans-serif;font-size:18px;font-weight:400;text-anchor:middle;dominant-baseline:auto">SHOP NOW →</text>

    <!-- Guarantee ribbon bottom-right -->
    <rect x="440" y="340" width="230" height="50" rx="0" fill="#2d3318" style="fill:rgb(45, 51, 24);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
    <rect x="440" y="340" width="4" height="50" fill="#E55A00" style="fill:rgb(229, 90, 0);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
    <text x="452" y="359" font-family="'Courier New', monospace" font-size="10" fill="#8fa040" letter-spacing="1" style="fill:rgb(143, 160, 64);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Courier New&quot;, monospace;font-size:10px;font-weight:400;text-anchor:start;dominant-baseline:auto">LIFETIME WARRANTY</text>
    <text x="452" y="377" font-family="'Courier New', monospace" font-size="10" fill="#8fa040" letter-spacing="1" style="fill:rgb(143, 160, 64);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Courier New&quot;, monospace;font-size:10px;font-weight:400;text-anchor:start;dominant-baseline:auto">FREE U.S. SHIPPING</text>

    <!-- TITAN star logo area top-right -->
    <text x="644" y="54" font-family="'Impact', 'Arial Black', sans-serif" font-size="30" fill="#4a5220" text-anchor="end" letter-spacing="2" style="fill:rgb(74, 82, 32);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Impact, &quot;Arial Black&quot;, sans-serif;font-size:30px;font-weight:400;text-anchor:end;dominant-baseline:auto">TITAN</text>
    <text x="644" y="78" font-family="'Courier New', monospace" font-size="11" fill="#4a5220" text-anchor="end" letter-spacing="3" style="fill:rgb(74, 82, 32);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Courier New&quot;, monospace;font-size:11px;font-weight:400;text-anchor:end;dominant-baseline:auto">SURVIVAL</text>

    <!-- Bottom border -->
    <rect x="0" y="392" width="680" height="8" fill="#E55A00" style="fill:rgb(229, 90, 0);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  </g>
</svg>